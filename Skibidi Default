    Title = "🔁 เล่นใหม่อัตโนมัติ",
    Default = false,
    Callback = function(state)
        AutoReplay = state

        if state then
            task.spawn(function()
                while AutoReplay do
                    local gui = player.PlayerGui:FindFirstChild("GameEnded")
                    if gui then
                        local frame = gui:FindFirstChild("Frame")
                        if frame then
                            local btn = frame:FindFirstChild("replay")
                            if btn then
                                btn:Activate()
