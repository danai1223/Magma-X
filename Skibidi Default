Window:Tag({
    Title = "I Hum Rex v1",
    Icon = "",
    Color = Color3.fromHex("#30ff6a"),
    Radius = 8,
})

local PlaceTab = Window:Tab({
    Title = "⚔️ ระบบวางยูนิต",
    Icon = "",
    Locked = false,
})

local FarmTab = Window:Tab({
    Title = "⚙️ ออโต้ฟาร์ม",
    Icon = "",
    Locked = false,
})

local Rep = game:GetService("ReplicatedStorage")

local AutoSilver = false
local AutoSpeaker = false
local AutoUTCP = false
local AutoUpgrade = false
local AutoStart = false
local AutoSkip = false
local AutoReplay = false
local SpeedX5 = false

PlaceTab:Toggle({
    Title = "🔫 วาง Upgraded Silver อัตโนมัติ",
    Default = false,
    Callback = function(state) AutoSilver = state end
})

PlaceTab:Toggle({
    Title = "🔊 วาง Ultimate Speakerguy อัตโนมัติ",
    Default = false,
    Callback = function(state) AutoSpeaker = state end
})

PlaceTab:Toggle({
    Title = "📷 วาง Colossal Camera อัตโนมัติ",
    Default = false,
    Callback = function(state) AutoUTCP = state end
})

PlaceTab:Toggle({
    Title = "⏫ อัพเกรดยูนิตทั้งหมด",
    Default = false,
    Callback = function(state) AutoUpgrade = state end
})

FarmTab:Toggle({
    Title = "🚀 เริ่มเกมอัตโนมัติ",
    Default = false,
    Callback = function(state) AutoStart = state end
})

FarmTab:Toggle({
    Title = "⏭️ ข้าม Wave อัตโนมัติ",
    Default = false,
    Callback = function(state) AutoSkip = state end
})

FarmTab:Toggle({
    Title = "🔁 เล่นใหม่อัตโนมัติ",
    Default = false,
    Callback = function(state) AutoReplay = state end
})

FarmTab:Toggle({
    Title = "⚡ เร่งความเร็ว Wave x5",
    Default = false,
    Callback = function(state) SpeedX5 = state end
})

task.spawn(function()
    while true do
        
        if AutoSilver then
            Rep.Event.placeTower:FireServer("UpgSilver", CFrame.new(440.57,96.48,502.21), false)
        end

        if AutoSpeaker then
            Rep.Event.placeTower:FireServer("UltimateSpeakerguy", CFrame.new(441.01,96.48,484.77), false)
        end

        if AutoUTCP then
            Rep.Event.placeTower:FireServer("UTCP", CFrame.new(460.73,96.08,482.94), false)
        end

        if AutoUpgrade then
            for i = 1,3 do
                Rep.Event.UpgradeTower:FireServer(tostring(i))
                task.wait(0.2)
            end
        end

        if AutoStart then
            Rep.GAME_START.readyButton:FireServer(true)
        end

        if AutoSkip then
            Rep.Event.waveSkip:FireServer(true)
        end

        if SpeedX5 then
            Rep.Game.Speed.Change:FireServer(5)
        end

        if AutoReplay then
            local player = game.Players.LocalPlayer
            local gui = player.PlayerGui:FindFirstChild("GameEnded")
            if gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("replay") then
                gui.Frame.replay:Activate()
            end
        end

        task.wait(1)
    end
end)

Window.Icon:Enable()
