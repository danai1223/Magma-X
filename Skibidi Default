    Callback = function(state)
        AutoSilver = state

        if state then
            task.spawn(function()
                while AutoSilver do
                    local args = {
                        "UpgSilver",
                        CFrame.new(440.5727844238281, 96.48703002929688, 502.2198181152344),
                        false
                    }

                    game:GetService("ReplicatedStorage")
                        :WaitForChild("Event")
                        :WaitForChild("placeTower")
