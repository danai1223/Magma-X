local FarmingSection = PlaceTab:Section({
    Title = "Level Farming",
    Desc = ""
})

local farming = false

local selectedTargets = {
    Chest = true,
    Barrel = true,
    Box = true
}

FarmingSection:Dropdown({
    Title = "Select Item",
    Values = {"Chest", "Barrel", "Box"},
    Multi = true,
    Default = {"Chest", "Barrel", "Box"},
    Callback = function(values)
        selectedTargets = {}
        for _, v in pairs(values) do
            selectedTargets[v] = true
        end
    end
})

FarmingSection:Toggle({
    Title = "Enabled",
    Default = false,
    Callback = function(state)
        farming = state

        if farming then
            task.spawn(function()

                local player = game.Players.LocalPlayer
                local itemsFolder = workspace:WaitForChild("Item")

                -- 🔥 ฟังก์ชันเอาตัวละครใหม่ (กันตายแล้วไม่ทำงาน)
                local function getChar()
                    local char = player.Character or player.CharacterAdded:Wait()
                    local hrp = char:WaitForChild("HumanoidRootPart")
                    local humanoid = char:WaitForChild("Humanoid")
                    return char, hrp, humanoid
                end

                local char, hrp, humanoid = getChar()

                -- 🔥 รีสตาร์ทตอนตาย
                player.CharacterAdded:Connect(function()
                    task.wait(1)
                    char, hrp, humanoid = getChar()
                end)

                -- 🔥 Noclip
                game:GetService("RunService").Stepped:Connect(function()
                    if farming and char then
                        for _, part in pairs(char:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end
                end)

                local function getPrompt(obj)
                    for _, v in ipairs(obj:GetDescendants()) do
                        if v:IsA("ProximityPrompt") and v.Enabled then
                            return v
                        end
                    end
                end

                while farming do
                    local found = false

                    for _, v in ipairs(itemsFolder:GetChildren()) do
                        if not farming then break end

                        if selectedTargets[v.Name] and v:IsA("BasePart") then
                            found = true

                            -- 🔥 วาปแบบนิ่ง
                            hrp.Velocity = Vector3.zero
                            hrp.AssemblyLinearVelocity = Vector3.zero
                            hrp.CFrame = v.CFrame * CFrame.new(0, -5, 0)

                            task.wait(0.08)

                            local prompt = getPrompt(v)
                            if prompt then
                                for i = 1, 20 do
                                    fireproximityprompt(prompt)
                                end
                            end

                            task.wait(0.05)
                        end
                    end

                    -- ❗ ถ้าไม่มีของ → ไป Void
                    if not found then
                        hrp.CFrame = CFrame.new(0, -500, 0) -- ปรับได้
                        task.wait(0.5)
                    end

                    task.wait(0.1)
                end

            end)
        end
    end
})

