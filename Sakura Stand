Config = Config or {
    Farming = false,
    FarmingV2 = false,
    AutoExecute = false,
    AutoSave = false,
    SelectedTargets = {"Chest","Barrel","Box"}
}

local function getConfigList()
    local files = {}
    for _,file in pairs(listfiles(folderName)) do
        if file:match(".json") then
            local name = file:match("([^/\\]+)%.json$")
            table.insert(files, name)
        end
    end
    return files
end

local function saveConfigFile(name)
    writefile(folderName.."/"..name..".json", HttpService:JSONEncode(Config))
end

local function loadConfigFile(name)
    local path = folderName.."/"..name..".json"
    if isfile(path) then
        local data = HttpService:JSONDecode(readfile(path))
        for k,v in pairs(data) do
            Config[k] = v
        end
    end
end

function SaveConfig()
    if Config.AutoSave and Config.CurrentConfig then
        saveConfigFile(Config.CurrentConfig)
    end
end

