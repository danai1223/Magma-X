local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local LP = Players.LocalPlayer
local Char, HRP

local function AddGunDropESP(obj)
    if not obj then return end

    if obj:IsA("BasePart") then
        if obj:FindFirstChild("GunESP") then return end

        local h = Instance.new("Highlight")
        h.Name = "GunESP"
        h.FillColor = Color3.fromRGB(255,255,0)
        h.OutlineColor = Color3.fromRGB(255,255,0)
        h.FillTransparency = 0.2
        h.OutlineTransparency = 0
        h.Adornee = obj
        h.Parent = obj

    elseif obj:FindFirstChild("Handle") then
        local handle = obj.Handle
        if handle:FindFirstChild("GunESP") then return end

        local h = Instance.new("Highlight")
        h.Name = "GunESP"
        h.FillColor = Color3.fromRGB(255,255,0)
        h.OutlineColor = Color3.fromRGB(255,255,0)
        h.FillTransparency = 0.2
        h.OutlineTransparency = 0
        h.Adornee = handle
        h.Parent = handle
    end
end

task.spawn(function()
    while task.wait(1) do
        local gunDrop = workspace:FindFirstChild("GunDrop", true)
        if gunDrop then
            AddGunDropESP(gunDrop)
        end
    end
end)

local ESPEnabled = true

local function UpdateChar()
    Char = LP.Character or LP.CharacterAdded:Wait()
    HRP = Char:WaitForChild("HumanoidRootPart")
end

UpdateChar()
LP.CharacterAdded:Connect(UpdateChar)

local function GetRole(plr)
    local b = plr:FindFirstChild("Backpack")
    local c = plr.Character

    if (b and b:FindFirstChild("Knife")) or (c and c:FindFirstChild("Knife")) then
        return "Murder"
    end

    if (b and b:FindFirstChild("Gun")) or (c and c:FindFirstChild("Gun")) then
        return "Sheriff"
    end

    return "Innocent"
end

local function GetColor(role)
    if role == "Murder" then
        return Color3.fromRGB(255,0,0)
    elseif role == "Sheriff" then
        return Color3.fromRGB(0,0,255)
    else
        return Color3.fromRGB(0,255,0)
    end
end

local function AddESP(plr)
    if plr == LP or not plr.Character then return end
    if plr.Character:FindFirstChild("ESP") then return end

    local h = Instance.new("Highlight")
    h.Name = "ESP"
    h.FillTransparency = 0.3
    h.OutlineTransparency = 0
    h.Adornee = plr.Character
    h.Parent = plr.Character
end

task.spawn(function()
    while task.wait(1) do
        if ESPEnabled then
            for _,plr in pairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character then
                    AddESP(plr)

                    local esp = plr.Character:FindFirstChild("ESP")
                    if esp then
                        local color = GetColor(GetRole(plr))
                        esp.FillColor = color
                        esp.OutlineColor = color
                    end
                end
            end
        end
    end
end)

local function GetMurder()
    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and GetRole(plr) == "Murder" then
            return plr
        end
    end
end

local function Predict(part)
    local pos = part.Position
    local vel = part.AssemblyLinearVelocity
    local distance = (HRP.Position - pos).Magnitude

    local bulletSpeed = 190
    local t = math.clamp(distance / bulletSpeed, 0.05, 0.25)

    local ping = 0.025

    if distance < 8 or vel.Magnitude < 1 then
        return pos
    end

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {part.Parent}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local downRay = workspace:Raycast(pos, Vector3.new(0, -6, 0), params)
    local upRay = workspace:Raycast(pos, Vector3.new(0, 6, 0), params)

    local horizontalVel = Vector3.new(vel.X, 0, vel.Z)

    if horizontalVel.Magnitude > 10 then
        horizontalVel = horizontalVel * 0.75
    end

    local yVel = vel.Y

    if downRay or upRay then
        yVel = 0
    else
        if math.abs(yVel) < 6 then
            yVel = 0
        else
            yVel = yVel * 0.3
        end
    end

    local finalVel = Vector3.new(horizontalVel.X, yVel, horizontalVel.Z)

    return pos + finalVel * (t + ping)
end

local function ShootOnce()
    local m = GetMurder()

    if m and m.Character then
        local target = m.Character:FindFirstChild("HumanoidRootPart")
        local gun = LP.Backpack:FindFirstChild("Gun") or LP.Character:FindFirstChild("Gun")

        if target and gun and gun:FindFirstChild("Handle") then
            local shoot = gun:FindFirstChild("Shoot")

            if shoot then
                local pos = Predict(target)

                shoot:FireServer(
                    CFrame.new(gun.Handle.Position, pos),
                    CFrame.new(pos)
                )
            end
        end
    end
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.ResetOnSpawn = false

local function Dragify(btn)
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = btn.Position
        end
    end)

    btn.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart

            btn.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

local function MakeButton(text,posY)
    local b = Instance.new("TextButton")
    b.Parent = ScreenGui
    b.Size = UDim2.new(0,70,0,70)
    b.Position = UDim2.new(0.92,0,posY,0)
    b.BackgroundColor3 = Color3.fromRGB(255,255,255)
    b.BackgroundTransparency = 0.75
    b.Text = text
    b.TextTransparency = 0.2

    Instance.new("UICorner",b).CornerRadius = UDim.new(1,0)

    local s = Instance.new("UIStroke",b)
    s.Transparency = 0.3
    s.Thickness = 1

    Dragify(b)

    return b
end

local ShootBtn = MakeButton("FIRE",0.75)
local GrabBtn = MakeButton("GRAB",0.60)

ShootBtn.MouseButton1Click:Connect(function()
    ShootOnce()
end)

GrabBtn.MouseButton1Click:Connect(function()
    local gunDrop = workspace:FindFirstChild("GunDrop",true)

    if gunDrop and HRP then
        if gunDrop:IsA("BasePart") then
            gunDrop.CFrame = HRP.CFrame
        elseif gunDrop:FindFirstChild("Handle") then
            gunDrop.Handle.CFrame = HRP.CFrame
        end
    end
end)

local UIVisible = true

local function ToggleUI()
    UIVisible = not UIVisible

    -- ซ่อน/โชว์ปุ่ม
    for _,v in pairs(ScreenGui:GetChildren()) do
        if v:IsA("TextButton") then
            v.Visible = UIVisible
        end
    end

    -- เปิด/ปิด ESP
    ESPEnabled = UIVisible

    -- ลบ Highlight ทั้งหมดถ้าปิด
    if not UIVisible then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("Highlight") then
                v:Destroy()
            end
        end
    end
end

-- ตรวจจับปุ่มคีย์บอร์ด
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.H then
        ToggleUI()
    end

    if input.KeyCode == Enum.KeyCode.E then
        ShootOnce()
    end

    if input.KeyCode == Enum.KeyCode.G then
        local gunDrop = workspace:FindFirstChild("GunDrop",true)

        if gunDrop and HRP then
            if gunDrop:IsA("BasePart") then
                gunDrop.CFrame = HRP.CFrame
            elseif gunDrop:FindFirstChild("Handle") then
                gunDrop.Handle.CFrame = HRP.CFrame
            end
        end
    end
end)
