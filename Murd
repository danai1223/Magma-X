
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local LP = Players.LocalPlayer
local Char, HRP

local ESPEnabled = true
local lastShot = 0
local shootCooldown = 0.12
local bulletSpeed = 220

local lastPositions = {}

local function UpdateChar()
    Char = LP.Character or LP.CharacterAdded:Wait()
    HRP = Char:WaitForChild("HumanoidRootPart")
end

UpdateChar()
LP.CharacterAdded:Connect(UpdateChar)

local function GetRole(plr)
    local b = plr:FindFirstChild("Backpack")
    local c = plr.Character
    if (b and b:FindFirstChild("Knife")) or (c and c:FindFirstChild("Knife")) then return "Murder" end
    if (b and b:FindFirstChild("Gun")) or (c and c:FindFirstChild("Gun")) then return "Sheriff" end
    return "Innocent"
end

local function GetColor(role)
    if role == "Murder" then return Color3.fromRGB(255,0,0) end
    if role == "Sheriff" then return Color3.fromRGB(0,0,255) end
    return Color3.fromRGB(0,255,0)
end

local function AddESP(plr)
    if plr == LP or not plr.Character then return end
    if plr.Character:FindFirstChild("ESP") then return end
    local h = Instance.new("Highlight")
    h.Name = "ESP"
    h.FillTransparency = 0.3
    h.OutlineTransparency = 0
    h.Adornee = plr.Character
    h.Parent = plr.Character
end

task.spawn(function()
    while task.wait(1) do
        if ESPEnabled then
            for _,plr in pairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character then
                    AddESP(plr)
                    local esp = plr.Character:FindFirstChild("ESP")
                    if esp then
                        local color = GetColor(GetRole(plr))
                        esp.FillColor = color
                        esp.OutlineColor = color
                    end
                end
            end
        end
    end
end)

local function GetMurder()
    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and GetRole(plr) == "Murder" then
            return plr
        end
    end
end

local function GetSmoothedVelocity(plr, part)
    if not lastPositions[plr] then
        lastPositions[plr] = part.Position
        return part.AssemblyLinearVelocity
    end

    local lastPos = lastPositions[plr]
    local currentPos = part.Position
    local vel = (currentPos - lastPos) / task.wait()
    lastPositions[plr] = currentPos

    return vel
end

local function Predict(plr, part, humanoid)
    local vel = GetSmoothedVelocity(plr, part)
    local flatVel = Vector3.new(vel.X, 0, vel.Z)

    local dist = (HRP.Position - part.Position).Magnitude
    local t = dist / bulletSpeed

    local state = humanoid:GetState()
    local yOffset = 0

    if state == Enum.HumanoidStateType.Jumping then
        yOffset = 3.5
    elseif state == Enum.HumanoidStateType.Freefall then
        yOffset = -2.5
    else
        yOffset = 0
    end

    local predictedXZ = part.Position + (flatVel * t * 0.85)
    local predictedY = part.Position.Y + (vel.Y * t) + yOffset

    return Vector3.new(predictedXZ.X, predictedY, predictedXZ.Z)
end

local function ShootOnce()
    if tick() - lastShot < shootCooldown then return end
    lastShot = tick()

    local m = GetMurder()
    if m and m.Character then
        local target = m.Character:FindFirstChild("HumanoidRootPart")
        local humanoid = m.Character:FindFirstChildOfClass("Humanoid")
        local gun = LP.Backpack:FindFirstChild("Gun") or LP.Character:FindFirstChild("Gun")

        if target and gun and humanoid and gun:FindFirstChild("Handle") then
            local shoot = gun:FindFirstChild("Shoot")
            if shoot then
                local pos = Predict(m, target, humanoid)
                local origin = gun.Handle.Position
                local cf = CFrame.lookAt(origin, pos)
                shoot:FireServer(cf, CFrame.new(pos))
            end
        end
    end
end

